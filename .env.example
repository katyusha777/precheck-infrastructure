# Required — Anthropic Sonnet 4.6 API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# Redis — short-lived job snapshots, submit throttling, and Perplexity cache.
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=precheck

# Server bind — deploy convention. APP_PORT/APP_HOST take precedence over PORT.
NODE_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8749
# Optional — legacy fallback port the NestJS server listens on (default 3000)
PORT=3000
LOG_LEVEL=debug
CORS_ORIGIN=
TRUST_PROXY=false
JSON_BODY_LIMIT=1mb

# Optional — override committed reference-data location, useful for mounted data
# in containers or split release/runtime directories.
# DATA_ROOT=/app/data

# Optional — shared-token protection. Leave blank to run without an app-level
# access gate. When set, the frontend shows an unlock screen and protected API
# routes require Authorization: Bearer <token>.
PRECHECK_ACCESS_TOKEN=

# Optional — simple Redis job retention, hard runtime, and submit throttling.
# Jobs start immediately; completed/failed/canceled reports expire after this TTL.
# Set PRECHECK_SUBMIT_LIMIT=0 to disable submission throttling.
PRECHECK_JOB_TTL_HOURS=24
PRECHECK_JOB_MAX_MINUTES=15
PRECHECK_SUBMIT_LIMIT=5
PRECHECK_SUBMIT_WINDOW_MS=600000
PRECHECK_DUMP_BADJSON=false

# Optional — point Puppeteer (PDF export) at a system Chromium instead of its
# bundled build. Set on servers where Chromium is installed via the package
# manager (e.g. the Proxmox LXC deploy): PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
# PUPPETEER_EXECUTABLE_PATH=

# Optional — Anthropic model + tuning
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_FABLE_TIMEOUT_MS=480000
ANTHROPIC_TIMEOUT_MS=240000
ANTHROPIC_MAX_RETRIES=4
ANTHROPIC_DEFAULT_MAX_TOKENS=4096
ANTHROPIC_CONCURRENCY=8

# Optional — OpenAI provider profile. The frontend exposes it only after both
# configured models pass an authenticated availability probe.
OPENAI_API_KEY=
OPENAI_TERRA_MODEL=gpt-5.6-terra
OPENAI_SOL_MODEL=gpt-5.6-sol
OPENAI_TIMEOUT_MS=240000
OPENAI_SOL_TIMEOUT_MS=480000
OPENAI_MAX_RETRIES=4
OPENAI_DEFAULT_MAX_TOKENS=4096
OPENAI_CONCURRENCY=8

# Optional — Perplexity Sonar (used to enrich each program contact in step 6 with
# a one-paragraph "why would this person care about this technology?" summary).
# Leave blank to skip enrichment; the rest of the report still renders.
PERPLEXITY_API_KEY=
PERPLEXITY_URL=https://api.perplexity.ai/chat/completions
PERPLEXITY_MODEL=sonar-pro
PERPLEXITY_TIMEOUT_MS=60000
PERPLEXITY_MAX_RETRIES=2
PERPLEXITY_CACHE_TTL_MS=604800000
PERPLEXITY_CONCURRENCY=2
