# PreCheck API environment — /srv/app/.env on the server.
# NOTE: `docker stack deploy` bakes these into the service spec at deploy
# time — re-run deploy.sh after editing.

# Required — Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# Database / Redis (host services)
DATABASE_URL=postgresql://precheck:CHANGE_ME@host:5432/precheck_api
POSTGRES_PASSWORD=
POSTGRES_DB=precheck_api
POSTGRES_USER=precheck
REDIS_URL=redis://host:6379
REDIS_KEY_PREFIX=precheck

# Server bind
NODE_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8749
TRUST_PROXY=1
LOG_LEVEL=info
JSON_BODY_LIMIT=1mb

# Required in production — Bearer-token auth for the API (min 24 chars).
PRECHECK_ACCESS_TOKEN=

# Concurrency — reports run CONCURRENTLY since v1.29 (the BullMQ queue and
# its knobs are gone). 8 fits ~4GB RAM; raise on bigger boxes.
PRECHECK_PIPELINE_CONCURRENCY=8
# Max simultaneous Anthropic HTTP calls across ALL running reports.
ANTHROPIC_CONCURRENCY=8
# Watchdog: fail a report with no step progress for this many minutes.
PRECHECK_STALL_MINUTES=30
# Auto-delete completed/failed jobs older than N days (0 = keep forever).
PRECHECK_JOB_RETENTION_DAYS=0

# Submission rate limit (per IP)
PRECHECK_SUBMIT_LIMIT=5
PRECHECK_SUBMIT_WINDOW_MS=600000

# PDF export — system Chromium inside the image.
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# Optional — Anthropic tuning
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_TIMEOUT_MS=240000
ANTHROPIC_MAX_RETRIES=4
ANTHROPIC_DEFAULT_MAX_TOKENS=4096

# Optional — Perplexity Sonar (contact enrichment; blank = skip)
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar-pro
PERPLEXITY_TIMEOUT_MS=60000
PERPLEXITY_MAX_RETRIES=2
PERPLEXITY_CACHE_TTL_MS=604800000
PERPLEXITY_CONCURRENCY=2
